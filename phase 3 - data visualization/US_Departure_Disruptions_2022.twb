      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#75a1c7'>✈ </run>
            <run>&lt;Sheet Name&gt;&#10;</run>
            <run fontcolor='#666666' fontsize='10'>Which airline brands exceed the network delay pattern?</run>
            <run>Æ&#10;</run>
            <run fontcolor='#666666' fontsize='10'>Minimum 100,000 departures | Length = delay rate</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='FLIGHTS+' name='federated.02yaj7x01enokk1c8yle81jr51b8' />
