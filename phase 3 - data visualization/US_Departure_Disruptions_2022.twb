            <groupfilter function='level-members' level='[DAY_OF_WEEK]' user:ui-action-filter='[Action20_054846B55E9A444EBB88381DEE28C032]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.02yaj7x01enokk1c8yle81jr51b8].[Action (MKT DESCRIPTION)]'>
