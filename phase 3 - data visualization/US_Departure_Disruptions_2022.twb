      <aliases enabled='yes' />
      <column caption='AIRCRAFT AGE' datatype='integer' name='[AIRCRAFT_AGE]' role='dimension' type='ordinal' />
      <column caption='AIRCRAFT ID' datatype='integer' name='[AIRCRAFT_ID (DIM_AIRCRAFTS.csv)]' role='dimension' type='ordinal' />
      <column datatype='integer' name='[AIRCRAFT_ID]' role='dimension' type='ordinal' />
      <column caption='ORIGIN AIRPORT CODE' datatype='string' name='[AIRPORT_CODE (DIM_STATIONS.csv1)]' role='dimension' type='nominal' />
      <column caption='DEST AIRPORT CODE' datatype='string' name='[AIRPORT_CODE]' role='dimension' type='nominal' />
      <column caption='ORIGIN AIRPORT NAME' datatype='string' name='[AIRPORT_NAME (DIM_STATIONS.csv1)]' role='dimension' type='nominal' />
      <column caption='DEST AIRPORT NAME' datatype='string' name='[AIRPORT_NAME]' role='dimension' type='nominal' />
      <column caption='AIR TIME' datatype='real' name='[AIR_TIME]' role='measure' type='quantitative' />
      <column caption='CANCELLATION REASON' datatype='string' name='[CANCELLATION_REASON]' role='dimension' type='nominal' />
      <column caption='OP CARRIER ID' datatype='integer' name='[CARRIER_ID (DIM_CARRIERS.csv1)]' role='dimension' type='ordinal' />
      <column caption='MKT CARRIER ID' datatype='integer' name='[CARRIER_ID]' role='dimension' type='ordinal' />
      <column caption='ORIGIN CITY' datatype='string' name='[CITY (DIM_STATIONS.csv1)]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column caption='DEST CITY' datatype='string' name='[CITY]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column caption='CLOUD COVER' datatype='integer' datatype-customized='true' name='[CLOUD_COVER]' role='measure' type='ordinal' />
      <column caption='AIRCRAFT AGE BUCKET' datatype='string' name='[Calculation_0343604515934212]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [AIRCRAFT_AGE] &lt; 6 THEN &quot;0-5 yr&quot; ELSEIF [AIRCRAFT_AGE] &lt; 16 THEN &quot;6-15 yr&quot; ELSEIF [AIRCRAFT_AGE] &lt; 31 THEN &quot;16-30 yr&quot; ELSE &quot;31+ yr&quot; END' />
      </column>
      <column caption='IS DEPARTED FLIGHT' datatype='boolean' name='[Calculation_0513205942067200]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[CANCELLATION_REASON] = &quot;Not Cancelled&quot;' />
      </column>
      <column caption='AVG TAXI OUT DEPARTED' datatype='real' default-format='n#,##0.00&quot; min&quot;;-#,##0.00&quot; min&quot;' name='[Calculation_0513205942255617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;    IF [Calculation_0513205942067200]&#13;&#10;    THEN [TAXI_OUT]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='AVG AIR TIME DEPARTED' datatype='real' default-format='n#,##0.00&quot; min&quot;;-#,##0.00&quot; min&quot;' name='[Calculation_0513205942444034]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;    IF [Calculation_0513205942067200]&#13;&#10;    THEN [AIR_TIME]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='AVG DEP DELAY DEPARTED' datatype='real' default-format='n#,##0.00&quot; min&quot;;-#,##0.00&quot; min&quot;' name='[Calculation_0513205942530051]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;    IF [Calculation_0513205942067200]&#13;&#10;    THEN [DEP_DELAY]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='TEMPERATURE BUCKET' datatype='string' name='[Calculation_0513205943570436]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [TEMPERATURE] &lt;= -10 THEN &quot;≤ -10 °C&quot;&#13;&#10;ELSEIF [TEMPERATURE] &lt;= 0 THEN &quot;-10 to 0 °C&quot;&#13;&#10;ELSEIF [TEMPERATURE] &lt;= 10 THEN &quot;0 to 10 °C&quot;&#13;&#10;ELSEIF [TEMPERATURE] &lt;= 20 THEN &quot;10 to 20 °C&quot;&#13;&#10;ELSEIF [TEMPERATURE] &lt;= 30 THEN &quot;20 to 30 °C&quot;&#13;&#10;ELSE &quot;&gt; 30 °C&quot;&#13;&#10;END' />
      </column>
      <column caption='DEP DELAY RATE' datatype='real' default-format='p0.00%' name='[Calculation_1766372341628930]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [DEP_DELAY] &gt;= 15&#13;&#10;    THEN [FLIGHT_ID]&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD([FLIGHT_ID])' />
      </column>
      <column caption='CANCELLATION RATE' datatype='real' default-format='p0.00%' name='[Calculation_1766372343013379]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF NOT [Calculation_0513205942067200]&#13;&#10;    THEN [FLIGHT_ID]&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD([FLIGHT_ID])' />
      </column>
      <column caption='LOW VISIBILITY RATE' datatype='real' default-format='p0.00%' name='[Calculation_1766372343209988]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [VISIBILITY] &gt; 0&#13;&#10;       AND [VISIBILITY] &lt;= 3&#13;&#10;    THEN [FLIGHT_ID]&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD([FLIGHT_ID])' />
      </column>
      <column caption='VISIBILITY BUCKET' datatype='string' name='[Calculation_1965659886026754]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [VISIBILITY] = 0 THEN &quot;0 mi&quot;&#13;&#10;ELSEIF [VISIBILITY] &lt;= 2 THEN &quot;0-2 mi&quot;&#13;&#10;ELSEIF [VISIBILITY] &lt;= 4 THEN &quot;2-4 mi&quot;&#13;&#10;ELSEIF [VISIBILITY] &lt;= 6 THEN &quot;4-6 mi&quot;&#13;&#10;ELSEIF [VISIBILITY] &lt;= 8 THEN &quot;6-8 mi&quot;&#13;&#10;ELSEIF [VISIBILITY] &lt;= 10 THEN &quot;8-10 mi&quot;&#13;&#10;ELSE &quot;&gt;10 mi&quot;&#13;&#10;END' />
      </column>
      <column caption='WIND GUST BUCKET' datatype='string' name='[Calculation_1965659886145539]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [WIND_GUST] &lt;= 10 THEN &quot;≤10 kt&quot;&#13;&#10;ELSEIF [WIND_GUST] &lt;= 20 THEN &quot;10-20 kt&quot;&#13;&#10;ELSEIF [WIND_GUST] &lt;= 30 THEN &quot;20-30 kt&quot;&#13;&#10;ELSE &quot;&gt;30 kt&quot;&#13;&#10;END' />
      </column>
      <column caption='DAY OF WEEK' datatype='string' name='[DAY_OF_WEEK]' role='dimension' type='nominal' />
      <column caption='DEP DELAY' datatype='integer' name='[DEP_DELAY]' role='measure' type='quantitative' />
