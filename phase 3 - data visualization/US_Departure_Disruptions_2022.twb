  <worksheets>
    <worksheet name='Aircraft Fleets Under Pressure'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#75a1c7'>✈</run>
            <run> &lt;Sheet Name&gt;&#10;</run>
            <run fontcolor='#666666' fontsize='10'>Do fleet profiles show different operating pressure?</run>
            <run>Æ&#10;</run>
            <run fontcolor='#666666' fontsize='10'>Unknown manufacturer excluded</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontsize='8'>THIS IS A PLACEHOLDER TEXT FOR THE COLUMN LABEL</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='FLIGHTS+' name='federated.02yaj7x01enokk1c8yle81jr51b8' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.02yaj7x01enokk1c8yle81jr51b8'>
            <column caption='AIRCRAFT AGE' datatype='integer' name='[AIRCRAFT_AGE]' role='dimension' type='ordinal' />
            <column caption='ORIGIN AIRPORT CODE' datatype='string' name='[AIRPORT_CODE (DIM_STATIONS.csv1)]' role='dimension' type='nominal' />
            <column caption='AIR TIME' datatype='real' name='[AIR_TIME]' role='measure' type='quantitative' />
            <column caption='CANCELLATION REASON' datatype='string' name='[CANCELLATION_REASON]' role='dimension' type='nominal' />
            <column caption='AIRCRAFT AGE BUCKET' datatype='string' name='[Calculation_0343604515934212]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [AIRCRAFT_AGE] &lt; 6 THEN &quot;0-5 yr&quot; ELSEIF [AIRCRAFT_AGE] &lt; 16 THEN &quot;6-15 yr&quot; ELSEIF [AIRCRAFT_AGE] &lt; 31 THEN &quot;16-30 yr&quot; ELSE &quot;31+ yr&quot; END' />
            </column>
            <column caption='IS DEPARTED FLIGHT' datatype='boolean' name='[Calculation_0513205942067200]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[CANCELLATION_REASON] = &quot;Not Cancelled&quot;' />
            </column>
            <column caption='AVG TAXI OUT DEPARTED' datatype='real' default-format='n#,##0.00&quot; min&quot;;-#,##0.00&quot; min&quot;' name='[Calculation_0513205942255617]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(&#13;&#10;    IF [Calculation_0513205942067200]&#13;&#10;    THEN [TAXI_OUT]&#13;&#10;    END&#13;&#10;)' />
            </column>
            <column caption='AVG AIR TIME DEPARTED' datatype='real' default-format='n#,##0.00&quot; min&quot;;-#,##0.00&quot; min&quot;' name='[Calculation_0513205942444034]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(&#13;&#10;    IF [Calculation_0513205942067200]&#13;&#10;    THEN [AIR_TIME]&#13;&#10;    END&#13;&#10;)' />
            </column>
            <column caption='AVG DEP DELAY DEPARTED' datatype='real' default-format='n#,##0.00&quot; min&quot;;-#,##0.00&quot; min&quot;' name='[Calculation_0513205942530051]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(&#13;&#10;    IF [Calculation_0513205942067200]&#13;&#10;    THEN [DEP_DELAY]&#13;&#10;    END&#13;&#10;)' />
            </column>
            <column caption='DEP DELAY RATE' datatype='real' default-format='p0.00%' name='[Calculation_1766372341628930]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [DEP_DELAY] &gt;= 15&#13;&#10;    THEN [FLIGHT_ID]&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD([FLIGHT_ID])' />
            </column>
            <column caption='CANCELLATION RATE' datatype='real' default-format='p0.00%' name='[Calculation_1766372343013379]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF NOT [Calculation_0513205942067200]&#13;&#10;    THEN [FLIGHT_ID]&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD([FLIGHT_ID])' />
            </column>
            <column caption='DEP DELAY' datatype='integer' name='[DEP_DELAY]' role='measure' type='quantitative' />
            <column datatype='real' name='[DISTANCE]' role='measure' type='quantitative' />
            <column datatype='integer' name='[FLIGHT_ID]' role='dimension' type='ordinal' />
            <column caption='AIRCRAFT MANUFACTURER' datatype='string' name='[MANUFACTURER]' role='dimension' type='nominal' />
            <column caption='TAXI OUT' datatype='integer' name='[TAXI_OUT]' role='measure' type='quantitative' />
            <column caption='WEATHER DESCRIPTION' datatype='string' name='[WEATHER_DESCRIPTION]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;No weather events present&quot;' value='No weather events' />
                <alias key='&quot;Significant weather event(s) present (Volcanic ash, Thunderstorm, Dust/sandstorm, Tornado, Freezing Precipitation)&quot;' value='Significant weather events' />
                <alias key='&quot;Weather event(s) present&quot;' value='Weather events' />
              </aliases>
            </column>
            <column caption='FLIGHTS' datatype='table' name='[__tableau_internal_object_id__].[FLIGHTS.csv_F5E44D0D69B94DE2B5BDEF124E0EF9FA]' role='measure' type='quantitative' />
            <column-instance column='[__tableau_internal_object_id__].[FLIGHTS.csv_F5E44D0D69B94DE2B5BDEF124E0EF9FA]' derivation='Count' name='[__tableau_internal_object_id__].[cnt:FLIGHTS.csv_F5E44D0D69B94DE2B5BDEF124E0EF9FA:qk]' pivot='key' type='quantitative' />
            <column-instance column='[DISTANCE]' derivation='Avg' name='[avg:DISTANCE:qk]' pivot='key' type='quantitative' />
